<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%highlight(%-5level) - %msg%n%nopex</pattern>
        </encoder>
    </appender>

    <!-- 1Password and other agents commonly serve key types MINA SSHD can't parse
         (sk-*, certificates). They're skipped harmlessly. Visible again under
         the debug / trace verbosity flags, which load logback-full-logs.xml. -->
    <logger name="org.eclipse.jgit.internal.transport.sshd.agent" level="error"/>

    <root level="warn">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
